{
 "scripts": {
  "cypress:open": "npx cypress open",
  "cypress:headless": "npx cypress run --browser chrome",
  "cypress:recebimentos": "npx cypress run --browser chrome --spec cypress/e2e/movimento/RECEBIMENTOS.cy.js",
  "cypress:Record": "npx cypress run --record chrome --spec cypress/e2e/movimento/RECEBIMENTOS_CAIXA_ESPECIFICO.cy.js",
  "merge:reports": "npx mochawesome-merge cypress/reports/*.json > cypress/reports/report.json",
  "generate:report": "npx marge cypress/reports/report.json --reportDir cypress/reports --inline",
  "report:full": "npm run merge:reports && npm run generate:report"
 },
 "dependencies": {
  "ntl": "^5.1.0"
 },
 "devDependencies": {
  "cypress": "^13.13.0",
  "dotenv": "^16.4.5",
  "mochawesome": "^7.1.4",
  "mochawesome-merge": "^5.0.0",
  "mochawesome-report-generator": "^6.3.0"
 }
}
